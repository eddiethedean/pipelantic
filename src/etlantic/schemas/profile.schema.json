{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://etlantic.dev/schemas/profile.json",
  "title": "ETLantic Profile",
  "type": "object",
  "required": ["name", "security_mode"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "orchestrator": { "type": "string" },
    "dataframe_engine": { "type": ["string", "null"] },
    "sql_engine": { "type": ["string", "null"] },
    "spark_engine": { "type": ["string", "null"] },
    "allow_trusted_sql": { "type": "boolean" },
    "spark_udf_policy": { "type": "string" },
    "spark_streaming": { "type": "boolean" },
    "required_sql_capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_spark_capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_orchestrator_capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assets": { "type": "object", "additionalProperties": { "type": "string" } },
    "bindings": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Deprecated. Prefer assets=. Diagnosed on load (PMCFG110)."
    },
    "implementation_overrides": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "secret_providers": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "resources": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "secrets": { "type": "object" },
    "plugin_allowlist": {
      "type": "object",
      "additionalProperties": { "type": ["string", "null"] }
    },
    "tenant": {
      "type": "string",
      "description": "Isolation tenant label for artifact/cache identity (0.20)."
    },
    "environment": {
      "type": "string",
      "description": "Isolation environment label for artifact/cache identity (0.20)."
    },
    "safe_io": {
      "type": "object",
      "description": "SafeIoPolicy overrides (approved roots, budgets, retention).",
      "additionalProperties": true
    },
    "outbound": {
      "type": "object",
      "description": "OutboundPolicy overrides (schemes, hosts, SSRF controls).",
      "additionalProperties": true
    },
    "require_plugin_probe": {
      "type": "boolean",
      "description": "When true, run isolated capability probes before load."
    },
    "security_domain": { "type": "string" },
    "security_mode": {
      "type": "string",
      "enum": ["development", "test", "production"],
      "description": "Explicit security posture for trust and drift fail-closed behavior."
    },
    "validation_policy": { "type": "string" },
    "portable_transform_policy": { "type": "string" },
    "concurrency": { "type": ["integer", "null"] },
    "timeout_seconds": { "type": ["number", "null"] },
    "retry_max_attempts": { "type": ["integer", "null"] },
    "schedule": { "type": "object" },
    "execution": { "type": "object" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false
}
